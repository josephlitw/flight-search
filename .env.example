# ── Amadeus for Developers（主要，免費 2000 次/月）──────────────
# 申請網址：https://developers.amadeus.com/register
# 申請後到 My Apps -> 建立 App -> 複製 API Key / Secret
AMADEUS_API_KEY=your_api_key_here
AMADEUS_API_SECRET=your_api_secret_here

# ── SerpApi（備用，需付費，但資料更即時）──────────────────────
